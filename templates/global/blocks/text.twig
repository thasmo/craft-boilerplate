{# @var block \craft\elements\Entry #}

{% embed 'sections/text.twig' with {
	anchor: block.id,
	headline: block.header.headline,
	level: block.header.headline_level.value,
	text: block.text,
} only %}
	{% block addition %}
		{% embed 'components/button.twig' with {
			label: 'regular button',
			url: '/',
			variants: {
				size: 'regular',
				appearance: 'solid',
			},
		} only %}{% endembed %}

		{% embed 'components/button.twig' with {
			label: 'small button',
			url: '/',
			variants: {
				size: 'small',
				appearance: 'solid',
			},
		} only %}{% endembed %}
	{% endblock %}
{% endembed %}

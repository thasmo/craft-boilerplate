{# @var entry \craft\elements\Entry #}

{% extends 'layouts/default.twig' %}

{% block content %}
	{% for block in entry.content %}
		{% set handle = block.type.handle|replace({'content_': ''}) %}

		{% embed 'components/section.twig' with {
			id: block.id,
		} %}
			{% block content %}
				{% include [
					'blocks/' ~ handle ~ '.twig',
				] with {
					block,
					page: entry,
				} only %}
			{% endblock %}
		{% endembed %}
	{% endfor %}
{% endblock %}

{# @var text string #}
{# @var level int #}
{# @var variant int #}

{% set min = 2 %}
{% set max = 6 %}
{% set level = max(min, min(max, level|default ?: min)) %}
{% set variant = variant|default ? max(min, min(max, variant|integer ?: min)) : level %}

<h{{ level }} class="h{{ variant }}">
	{{ text|nl2br }}
</h{{ level }}>

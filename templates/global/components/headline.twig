{# @var text string #}
{# @var anchor string #}
{# @var level int #}
{# @var size int #}
{# @var variants object #}

{# <editor-fold desc="defaults" defaultstate="collapsed"> #}
{% set min = 2 %}
{% set max = 6 %}
{% set anchor = anchor|default %}
{% set level = level ? max(min, min(max, level|default ?: min)) : null %}
{% set size = size|default ? max(min, min(max, size|integer ?: min)) : level %}
{% set variants = {}|merge(variants|default({}))|filter %}
{# </editor-fold> #}

{# <editor-fold desc="variants" defaultstate="collapsed"> #}
{% set variants %}
	data-size="{{ size }}"
	{% for name, value in variants %}
		data-{{ name }}="{{ value }}"
	{% endfor %}
{% endset %}
{# </editor-fold> #}

<h{{ level }} {{ anchor ? 'id="' ~ anchor ~ '"' }} class="headline-{{ size }}" {{ variants }}>
	{{ text|nl2br }}
</h{{ level }}>
